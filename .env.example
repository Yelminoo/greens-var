# -----------------------------------------------
# ENV REFERENCE — do not put real values here
#
# Files used:
#   .env.development  → npm run dev   (committed, no secrets)
#   .env.production   → production    (NOT committed, fill on server)
#   .env.local        → local secret overrides (NOT committed)
# -----------------------------------------------

DATABASE_URL=postgresql://user:password@localhost:5432/greensvar

SESSION_SECRET=min-32-char-random-string

# Gmail (active while setting up Resend)
GMAIL_USER=yourgmail@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Resend (swap in when domain is verified)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

QUOTE_FROM_EMAIL=yourgmail@gmail.com
QUOTE_TO_EMAIL=business-inbox@gmail.com

# bcrypt hash — generate with:
# node -e "require('bcryptjs').hash('yourpassword',12).then(console.log)"
ADMIN_PASSWORD_HASH=

HOST=greensvar.com
PORT=3000
