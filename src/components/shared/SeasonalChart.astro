---
interface Props {
  products: { name: string; seasons: number[] }[]
  accentColor: string
}

const { products, accentColor } = Astro.props
const MONTHS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec']
const currentMonth = new Date().getMonth() + 1
---

<div class="overflow-x-auto rounded-2xl border border-gray-100 bg-white shadow-sm">
  <table class="w-full text-sm min-w-[640px]">
    <thead>
      <tr style="background-color: var(--color-cream);">
        <th class="text-left px-6 py-4 font-semibold font-mono text-xs uppercase tracking-wider opacity-60 w-40">Product</th>
        {MONTHS.map((m, i) => (
          <th class={`px-2 py-4 font-mono text-xs text-center font-semibold ${i + 1 === currentMonth ? 'rounded-t' : ''}`}
              style={i + 1 === currentMonth ? `color: ${accentColor}` : 'opacity: 0.4'}>
            {m}
          </th>
        ))}
      </tr>
    </thead>
    <tbody>
      {products.map((p, ri) => (
        <tr class={`border-t border-gray-50 ${ri % 2 === 0 ? '' : 'bg-gray-50/50'}`}>
          <td class="px-6 py-4 font-medium text-sm">{p.name}</td>
          {MONTHS.map((_, i) => {
            const inSeason = p.seasons.includes(i + 1)
            const isCurrent = i + 1 === currentMonth
            return (
              <td class="px-2 py-4 text-center">
                {inSeason ? (
                  <span
                    class={`inline-block w-5 h-5 rounded-full mx-auto ${isCurrent ? 'ring-2 ring-offset-1 scale-125' : ''}`}
                    style={`background-color: ${accentColor}; ${isCurrent ? `ring-color: ${accentColor}` : 'opacity: 0.75'}`}
                    title={`${p.name} available in ${MONTHS[i]}`}
                  ></span>
                ) : (
                  <span class="inline-block w-2 h-2 rounded-full bg-gray-200 mx-auto opacity-30"></span>
                )}
              </td>
            )
          })}
        </tr>
      ))}
    </tbody>
  </table>
  <div class="px-6 py-3 border-t border-gray-100 flex items-center gap-6 text-xs opacity-50">
    <span class="flex items-center gap-1.5">
      <span class="inline-block w-3 h-3 rounded-full" style={`background-color: ${accentColor}`}></span>
      In season
    </span>
    <span class="flex items-center gap-1.5">
      <span class="inline-block w-3 h-3 rounded-full border-2" style={`border-color: ${accentColor}`}></span>
      Current month
    </span>
  </div>
</div>
