---
import BrandLayout from '../../layouts/BrandLayout.astro'
import SeasonalChart from '../../components/shared/SeasonalChart.astro'
import ProductCard from '../../components/shared/ProductCard.astro'
import { getProductsByBrand } from '../../db/products'

const variegataProducts = await getProductsByBrand('variegata')
const IS_DEV = import.meta.env.DEV
const dbNotReady = IS_DEV && variegataProducts.length === 0
---

<BrandLayout title="Fresh Thai Vegetables & Herbs" brand="variegata">

  {dbNotReady && (
    <div style="background:#1C2B1E;border-bottom:3px solid #1A9E8F;padding:16px 24px;font-family:monospace;font-size:13px;color:white;">
      <strong style="color:#1A9E8F;">⚠️ DEV — Database not set up yet.</strong>
      <span style="opacity:0.6;margin:0 12px">Products table is empty or missing. Run in terminal:</span>
      <code style="background:rgba(255,255,255,0.1);padding:4px 10px;border-radius:6px;color:#A8D635">
        npm run db:push &amp;&amp; npm run db:seed
      </code>
    </div>
  )}

  <!-- Hero Banner -->
  <section class="relative min-h-[70vh] flex items-end overflow-hidden" style="background-color: #001a14;">
    <div class="absolute inset-0 opacity-50"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-black/90 via-black/30 to-transparent"></div>
    <div class="absolute top-12 right-12 w-64 h-64 rounded-full opacity-20 blur-2xl"
         style="background-color: var(--color-teal-veg)"></div>

    <div class="relative max-w-7xl mx-auto px-6 pb-20 w-full">
      <span class="tag mb-4 inline-block" style="background-color: var(--color-teal-veg); color: white;">
        Farm to Export
      </span>
      <h1 class="text-5xl md:text-6xl font-bold text-white mb-4" style="font-family: var(--font-heading)">
        Thai Vegetables &<br />Aromatic Herbs
      </h1>
      <p class="text-white/60 max-w-lg text-lg mb-8">
        Authentic Thai vegetables and culinary herbs, grown by specialist farmers and exported fresh or frozen. The ingredients global kitchens rely on.
      </p>
      <a href="/quote" class="btn-primary" style="background-color: var(--color-teal-veg);">
        Request a Quote
      </a>
    </div>
  </section>

  <!-- Seasonal Chart -->
  <section class="py-20 px-6" style="background-color: var(--color-cream);">
    <div class="max-w-7xl mx-auto">
      <p class="text-sm font-mono font-semibold uppercase tracking-widest opacity-50 mb-2">Availability</p>
      <h2 class="section-title mb-3">Seasonal Chart</h2>
      <p class="opacity-60 mb-10 max-w-xl">Typical availability windows for our vegetable and herb range. Many lines are available year-round — contact us for current stock.</p>
      <SeasonalChart products={variegataProducts} accentColor="var(--color-teal-veg)" />
    </div>
  </section>

  <!-- Product Gallery -->
  <section class="py-20 px-6">
    <div class="max-w-7xl mx-auto">
      <p class="text-sm font-mono font-semibold uppercase tracking-widest opacity-50 mb-2">Our Products</p>
      <h2 class="section-title mb-10">Product Range</h2>
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {variegataProducts.map(p => (
          <ProductCard
            slug={p.slug}
            name={p.name}
            variety={p.variety}
            description={p.description}
            image={p.image}
            unit={p.unit}
            tags={p.tags}
            accentColor="var(--color-teal-veg)"
            brand="variegata"
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Quote CTA -->
  <section class="py-20 px-6" style="background-color: var(--color-teal-veg);">
    <div class="max-w-3xl mx-auto text-center text-white">
      <h2 class="text-3xl md:text-4xl font-bold mb-4" style="font-family: var(--font-heading)">
        Ready to Source?
      </h2>
      <p class="opacity-80 mb-8">Build your quote request and we'll come back with pricing and availability within 24 hours.</p>
      <a href="/quote" class="inline-flex items-center gap-2 bg-white font-semibold px-8 py-4 rounded-full transition-transform hover:scale-105"
         style="color: var(--color-teal-veg)">
        🧾 Build Your Quote
      </a>
    </div>
  </section>
</BrandLayout>

<script>
  import { addToBasket } from '../../lib/quoteBasket'

  document.querySelectorAll('.add-to-quote').forEach(btn => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLButtonElement
      addToBasket({
        slug: el.dataset.slug!,
        name: el.dataset.name!,
        unit: el.dataset.unit!,
        quantity: 1,
        brand: 'variegata',
      })
      el.textContent = '✓ Added'
      setTimeout(() => { el.textContent = '+ Add to Quote' }, 1500)
    })
  })
</script>
