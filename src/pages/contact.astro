---
import MainLayout from '../layouts/MainLayout.astro'
---

<MainLayout title="Contact Us">
  <section class="max-w-4xl mx-auto px-6 py-20">
    <h1 class="text-4xl font-bold font-heading mb-4" style="color: var(--color-green-primary)">Contact Us</h1>
    <p class="text-lg text-gray-500 mb-16 max-w-xl">
      Ready to source? Have a question about availability or logistics? Reach out — we reply within 1 business day.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
      <!-- Contact details -->
      <div class="space-y-8">
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-1">Email</p>
          <a href="mailto:info@greensvar.com" class="text-lg font-medium hover:text-green-600 transition-colors">
            info@greensvar.com
          </a>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-1">Phone / LINE</p>
          <p class="text-lg font-medium">+66 XX XXX XXXX</p>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-1">Location</p>
          <p class="text-lg font-medium">Bangkok, Thailand</p>
          <p class="text-sm text-gray-400">Exporting to EU, Middle East, Asia</p>
        </div>
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-2">Quick Links</p>
          <div class="flex gap-3">
            <a href="/fruithai/" class="text-sm px-4 py-2 rounded-full border" style="border-color: var(--color-orange-fruit); color: var(--color-orange-fruit);">
              FruThai
            </a>
            <a href="/variegata/" class="text-sm px-4 py-2 rounded-full border" style="border-color: var(--color-teal-veg); color: var(--color-teal-veg);">
              Variegata
            </a>
          </div>
        </div>
      </div>

      <!-- Contact form -->
      <form class="space-y-5" action="/api/contact" method="POST">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="name">Name</label>
          <input id="name" name="name" type="text" required
            class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-green-300"
            placeholder="Your full name" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="email">Email</label>
          <input id="email" name="email" type="email" required
            class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-green-300"
            placeholder="you@company.com" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="company">Company</label>
          <input id="company" name="company" type="text"
            class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-green-300"
            placeholder="Optional" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1" for="message">Message</label>
          <textarea id="message" name="message" rows="4" required
            class="w-full border border-gray-200 rounded-lg px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-green-300 resize-none"
            placeholder="Tell us what you're looking for…"></textarea>
        </div>
        <button type="submit" class="w-full btn-primary py-3" style="background-color: var(--color-green-primary)">
          Send Message
        </button>
      </form>
    </div>
  </section>
</MainLayout>
