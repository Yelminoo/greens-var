# ── Database ──────────────────────────────────────────────────────────────────
# Provided automatically by Railway PostgreSQL plugin
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Session ───────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=change-this-to-a-long-random-string

# ── Email (Gmail) ─────────────────────────────────────────────────────────────
GMAIL_USER=yourgmail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx
QUOTE_FROM_NAME=Greens Variegated
QUOTE_TO_EMAIL=yourgmail@gmail.com

# ── Routing ───────────────────────────────────────────────────────────────────
# Set to true only when you have greensvar.com + subdomains pointed at this server
SUBDOMAIN_ROUTING=false

# ── PDF Storage ───────────────────────────────────────────────────────────────
# Writable folder for generated PDF invoices
PDF_STORAGE_DIR=/app/storage/quotes
